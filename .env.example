# AWS
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=ap-south-1

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cloudsense

# ML service
ML_DETECT_URL=http://127.0.0.1:8001/detect
ML_ANOMALY_DETECT_URL=http://127.0.0.1:8001/detect
ML_FORECAST_URL=http://127.0.0.1:8001/forecast

# FinOps assistant
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# EC2 optimization
EC2_INSTANCE_ID=
EC2_OPTIMIZATION_INSTANCE_NAMES=
EC2_OPTIMIZATION_ACTION=stop
EC2_OPTIMIZATION_AUTO=false
EC2_OPTIMIZATION_BACKGROUND=false
EC2_OPTIMIZATION_POLICY_INTERVAL_SECONDS=30
EC2_OPTIMIZATION_SEARCH_REGIONS=

# Chaos mode
ENABLE_CHAOS_MODE=false
MAX_CHAOS_INSTANCES=1
CHAOS_ANOMALY_DELAY_SECONDS=15
CHAOS_OPTIMIZE_DELAY_SECONDS=15

# Dashboard and analytics
AUTOMATION_LOG_READ_LIMIT=500
UNIT_COUNT=1
UNIT_TYPE=workspace

# Email notifications
OPTIMIZATION_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
